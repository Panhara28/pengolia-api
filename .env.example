APP_NAME=PentestFlow API
APP_ENV=development
API_V1_PREFIX=/api/v1

DATABASE_URL=postgresql+psycopg://pentestflow:pentestflow@postgres:5432/pentestflow
REDIS_URL=redis://redis:6379/0

JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Auth tokens are set as httpOnly cookies. COOKIE_SECURE must be true for
# any deployment served over HTTPS (local http dev only works with it false).
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Uses a different Redis DB index (1) than Celery's broker (0).
RATE_LIMIT_STORAGE_URI=redis://redis:6379/1

ZAP_DOCKER_IMAGE=ghcr.io/zaproxy/zaproxy:stable
SCAN_OUTPUT_DIR=/app/scan_outputs
REPORT_OUTPUT_DIR=/app/reports
# Must match the `name:` of the scan_outputs volume in docker-compose.yml --
# the worker mounts this named volume (not a host path) into ZAP's sibling container.
SCAN_OUTPUT_VOLUME_NAME=pentestflow_scan_outputs

ALLOW_LOCALHOST=true
ALLOW_PRIVATE_IPS=true
BLOCK_PUBLIC_TARGETS=true
REQUIRE_SCOPE_CONFIRMATION=true
